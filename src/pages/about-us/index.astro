---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import AboutCta from '../../components/AboutCta.astro';
import { getAboutContent, getSharedCta } from '../../lib/content';

const { site, about } = await getAboutContent();
const cta = getSharedCta(site);

const expertise = about.sections.find((s) => s.title === 'Our Expertise') ?? about.sections[1];
const commitment =
  about.sections.find((s) => s.title === 'Our Commitment') ?? about.sections[2];
---

<SiteLayout title={about.title} description={about.intro}>
  <section class="about-hero">
    <div class="container-site">
      <div class="about-hero-top reveal" data-reveal>
        <p class="about-eyebrow">{about.eyebrow}</p>
        <h1 class="about-hero-title">{about.heroTitle}</h1>
      </div>

      <div class="about-hero-media reveal" data-reveal style="--reveal-delay: 100ms">
        <img src={about.heroImage} alt="" />
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container-site">
      <PageIntro title={about.introTitle} description={about.intro} />

      <div class="about-split reveal" data-reveal>
        <div class="about-split-media">
          <img src={about.missionImage} alt="" />
        </div>
        <div class="about-split-copy">
          <p class="about-label">{about.missionLabel}</p>
          <h2>{about.missionTitle}</h2>
          <p class="about-split-desc">{expertise?.body}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light pt-0">
    <div class="container-site">
      <div class="about-split is-reverse reveal" data-reveal>
        <div class="about-split-copy">
          <p class="about-label">{about.visionLabel}</p>
          <h2>{about.visionTitle}</h2>
          <p class="about-split-desc">{commitment?.body}</p>
        </div>
        <div class="about-split-media">
          <img src={about.visionImage} alt="" />
        </div>
      </div>
    </div>
  </section>

  <AboutCta
    title={about.ctaTitle || cta.title}
    primaryLabel={cta.primaryLabel}
    primaryUrl={site.signInUrl}
    points={cta.points}
    imageUrl={cta.imageUrl}
  />
</SiteLayout>
