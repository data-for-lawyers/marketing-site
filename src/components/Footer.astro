---
import { defaultNavLinks, type NavLink } from '../lib/nav';
import { isPageEnabled, type PagesEnabled } from '../lib/pages';
import { withBase } from '../lib/paths';

interface Props {
  companyName: string;
  tagline: string;
  phone: string;
  email: string;
  linkedInUrl: string;
  demoUrl: string;
  signInUrl: string;
  logoUrl: string;
  demoCtaLabel?: string;
  signInLabel?: string;
  companyHeading?: string;
  resourcesHeading?: string;
  getStartedHeading?: string;
  copyrightSuffix?: string;
  navLinks?: readonly NavLink[];
  pagesEnabled?: Partial<PagesEnabled>;
}

const {
  companyName,
  tagline,
  phone,
  email,
  linkedInUrl,
  demoUrl,
  signInUrl,
  logoUrl,
  demoCtaLabel = 'Book a demo',
  signInLabel = 'Log in',
  companyHeading = 'Company',
  resourcesHeading = 'Resources',
  getStartedHeading = 'Get started',
  copyrightSuffix = 'All rights reserved.',
  navLinks = defaultNavLinks,
  pagesEnabled,
} = Astro.props;

const year = new Date().getFullYear();
const phoneHref = `tel:${phone.replace(/[^\d+]/g, '')}`;
const links = navLinks.length ? [...navLinks] : [...defaultNavLinks];

const companyLinks = [
  { href: '/about-us', label: 'About Us' },
  { href: '/services', label: 'Services' },
  { href: '/contact-us', label: 'Contact' },
]
  .filter((link) => isPageEnabled(pagesEnabled, link.href))
  .map((link) => ({ ...link, href: withBase(link.href) }));

const resourceLinks = [
  ...links
    .filter((link) => !['/about-us', '/services'].includes(link.href))
    .map((link) => ({ ...link, href: withBase(link.href) })),
  ...(isPageEnabled(pagesEnabled, '/privacy-policy')
    ? [{ href: withBase('/privacy-policy'), label: 'Privacy Policy' }]
    : []),
  ...(isPageEnabled(pagesEnabled, '/terms-of-service')
    ? [{ href: withBase('/terms-of-service'), label: 'Terms of Service' }]
    : []),
  { href: linkedInUrl, label: 'LinkedIn', external: true as const },
];
---

<footer class="site-footer">
  <div class="container-site">
    <div class="grid gap-10 lg:grid-cols-[1.3fr_1fr_1fr_1fr]">
      <div>
        <a href={withBase('/')} class="flex items-center no-underline">
          <img src={logoUrl} alt={companyName} class="h-12 w-auto sm:h-14" />
        </a>
        <p class="text-soft mt-4 max-w-xs text-sm leading-7">{tagline}</p>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold">{companyHeading}</p>
        <div class="grid gap-2.5">
          {companyLinks.map((link) => <a href={link.href} class="footer-link">{link.label}</a>)}
        </div>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold">{resourcesHeading}</p>
        <div class="grid gap-2.5">
          {
            resourceLinks.map((link) =>
              'external' in link && link.external ? (
                <a href={link.href} class="footer-link" target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              ) : (
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              ),
            )
          }
        </div>
      </div>

      <div>
        <p class="mb-4 text-sm font-semibold">{getStartedHeading}</p>
        <div class="grid gap-2.5">
          <a href={withBase('/contact-us')} class="footer-link">{demoCtaLabel}</a>
          <a href={withBase(signInUrl)} class="footer-link">{signInLabel}</a>
          <a href={phoneHref} class="footer-link">{phone}</a>
          <a href={`mailto:${email}`} class="footer-link">{email}</a>
        </div>
      </div>
    </div>

    <p class="mt-12 border-t border-white/10 pt-6 text-sm text-white/45">
      © {year} {companyName}. {copyrightSuffix}
    </p>
  </div>
</footer>
