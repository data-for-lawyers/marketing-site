---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import StatsSection from '../components/StatsSection.astro';
import Services from '../components/Services.astro';
import Comparison from '../components/Comparison.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
import { getSharedCta, getSiteContent } from '../lib/content';

const { site, homepage } = await getSiteContent();
const cta = getSharedCta(site);
---

<BaseLayout title={`${site.companyName} | ${site.tagline}`} description={homepage.heroSubtitle}>
  <Header
    logoUrl={site.logoLightUrl || site.logoUrl}
    phone={site.phone}
    ctaLabel={site.headerCtaLabel}
    ctaUrl="/contact-us"
    signInUrl={site.signInUrl}
    signInLabel={site.signInLabel}
    navLinks={site.navLinks}
  />

  <main class="home-main">
    <Hero
      title={homepage.heroTitle}
      subtitle={homepage.heroSubtitle}
      ctaLabel={homepage.heroCta}
      secondaryCtaLabel={homepage.heroSecondaryCta}
      platformUrl={site.signInUrl}
      imageUrl={homepage.heroImage}
    />

    <StatsSection carriers={homepage.carriers} />

    <Services
      title={homepage.servicesTitle}
      description={homepage.servicesDescription}
      eyebrow={homepage.servicesEyebrow}
      hint={homepage.servicesHint}
      ctaLabel={homepage.servicesCtaLabel}
      services={homepage.services}
    />

    <Comparison
      title={homepage.comparisonTitle}
      description={homepage.comparisonDescription}
      eyebrow={homepage.comparisonEyebrow}
      other={homepage.comparisonOther}
      ours={homepage.comparisonOurs}
    />

    <Testimonials
      eyebrow={homepage.testimonialsEyebrow}
      items={homepage.testimonials}
    />

    <FAQ
      title={homepage.faqTitle}
      description={homepage.faqDescription}
      eyebrow={homepage.faqEyebrow}
      items={homepage.faqs}
      showAllLink={site.pagesEnabled.faqs}
      browseAllLabel={homepage.faqBrowseAllLabel}
    />

    <CtaBand
      title={cta.title}
      description={homepage.ctaDescription}
      eyebrow={homepage.ctaEyebrow}
      primaryLabel={cta.primaryLabel}
      points={cta.points}
    />
  </main>

  <Footer
    companyName={site.companyName}
    tagline={site.tagline}
    phone={site.phone}
    email={site.email}
    linkedInUrl={site.linkedInUrl}
    signInUrl={site.signInUrl}
    logoUrl={site.logoLightUrl}
    demoCtaLabel={site.demoCtaLabel}
    signInLabel={site.signInLabel}
    termsLabel={site.termsLabel}
    companyHeading={site.footerCompanyHeading}
    resourcesHeading={site.footerResourcesHeading}
    getStartedHeading={site.footerGetStartedHeading}
    copyrightSuffix={site.copyrightSuffix}
    navLinks={site.navLinks}
    pagesEnabled={site.pagesEnabled}
  />
</BaseLayout>
