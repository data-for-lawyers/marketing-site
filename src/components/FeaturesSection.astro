---
import SectionHeader from './SectionHeader.astro';

type Feature = {
  title: string;
  description: string;
};

interface Props {
  title: string;
  description: string;
  features: readonly Feature[];
}

const { title, description, features } = Astro.props;
---

<section class="section section-dark">
  <div class="container-site section-stack">
    <div class="reveal" data-reveal>
      <SectionHeader title={title} description={description} align="center" tone="dark" />
    </div>

    <div class="feature-grid">
      {
        features.map((feature, index) => (
          <article
            class="feature-tile reveal"
            data-reveal
            style={`--reveal-delay: ${index * 70}ms`}
          >
            <div class="feature-tile-icon" aria-hidden="true">
              {index === 0 && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 18h6" />
                  <path d="M10 22h4" />
                  <path d="M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2z" />
                </svg>
              )}
              {index === 1 && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 19V5" />
                  <path d="M4 19h16" />
                  <path d="M8 16V10" />
                  <path d="M12 16V7" />
                  <path d="M16 16v-4" />
                </svg>
              )}
              {index === 2 && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" />
                </svg>
              )}
              {index === 3 && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" />
                </svg>
              )}
            </div>
            <h3 class="feature-tile-title">{feature.title}</h3>
            <p class="feature-tile-desc">{feature.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
