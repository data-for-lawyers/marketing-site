---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getTermsContent } from '../../lib/content';
import { parseLegalBody } from '../../lib/legal';
import { notFoundIfDisabled } from '../../lib/pages';

const { site, terms } = await getTermsContent();
const disabled = notFoundIfDisabled(site.pagesEnabled, '/terms-of-service');
if (disabled) return disabled;

const sections = terms.sections.map((section) => ({
  title: section.title,
  blocks: parseLegalBody(section.body),
}));
---

<SiteLayout title={terms.title} description={terms.description}>
  <PageHero title={terms.title} eyebrow={terms.eyebrow} />

  <section class="section section-light">
    <div class="container-site">
      <PageIntro title={terms.introTitle} description={terms.intro} />

      <div class="prose legal-prose mx-auto max-w-3xl rounded-[1.5rem] border border-[var(--color-border)] bg-white p-8 md:p-12">
        {
          sections.map((section) => (
            <section class="legal-section">
              <h2>{section.title}</h2>
              {section.blocks.map((block) => {
                if (block.type === 'heading') return <h3>{block.text}</h3>;
                if (block.type === 'list') {
                  return (
                    <ul class="legal-list">
                      {block.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  );
                }
                return <p>{block.text}</p>;
              })}
            </section>
          ))
        }
        <p>
          Contact <a href={`mailto:${site.email}`}>{site.email}</a> or call{' '}
          <a href={`tel:${site.phone.replace(/[^\d+]/g, '')}`}>{site.phone}</a>.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
