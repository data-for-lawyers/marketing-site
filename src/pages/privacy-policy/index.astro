---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getPrivacyContent } from '../../lib/content';

const { site, privacy } = await getPrivacyContent();
---

<SiteLayout title={privacy.title} description={privacy.description}>
  <PageHero title={privacy.title} eyebrow={privacy.eyebrow} />

  <section class="section section-light">
    <div class="container-site">
      <PageIntro title={privacy.introTitle} description={privacy.intro} />

      <div class="prose mx-auto max-w-3xl rounded-[1.5rem] border border-[var(--color-border)] bg-white p-8 md:p-12">
        {
          privacy.sections.map((section) => (
            <>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
            </>
          ))
        }
        <p>
          Questions? Contact us at <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
