---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getAboutContent, getSharedCta } from '../../lib/content';
import { notFoundIfDisabled } from '../../lib/pages';

const { site, about } = await getAboutContent();
const disabled = notFoundIfDisabled(site.pagesEnabled, '/about-us');
if (disabled) return disabled;
const cta = getSharedCta(site);
---

<SiteLayout title={about.title} description={about.intro}>
  <PageHero eyebrow={about.eyebrow || about.title} title={about.heroTitle} />

  {
    about.heroImage && (
      <section class="about-hero-image-section">
        <div class="about-hero-media reveal" data-reveal>
          <img src={about.heroImage} alt="" />
        </div>
      </section>
    )
  }

  <section class="section section-light about-intro-section">
    <div class="container-site">
      <div class="about-intro reveal" data-reveal>
        <p class="section-kicker">{about.introEyebrow || 'Overview'}</p>
        <h2 class="about-intro-title">{about.introTitle}</h2>
        <p class="about-intro-copy">{about.intro}</p>
      </div>
    </div>
  </section>

  <section class="section section-light about-split-section">
    <div class="container-site">
      <div class="about-split reveal" data-reveal>
        <div class="about-split-copy">
          <p class="section-kicker">{about.missionLabel}</p>
          <h2>{about.missionTitle}</h2>
          <p class="about-split-desc">{about.missionBody}</p>
        </div>
        <div class="about-split-media">
          <img src={about.missionImage} alt="" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light about-split-section pt-0">
    <div class="container-site">
      <div class="about-split is-reverse reveal" data-reveal>
        <div class="about-split-copy">
          <p class="section-kicker">{about.visionLabel}</p>
          <h2>{about.visionTitle}</h2>
          <p class="about-split-desc">{about.visionBody}</p>
        </div>
        <div class="about-split-media">
          <img src={about.visionImage} alt="" />
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title={about.ctaTitle || cta.title}
    description={about.ctaDescription || ''}
    eyebrow={about.ctaEyebrow || 'Get Started'}
    primaryLabel={cta.primaryLabel}
    points={cta.points}
  />
</SiteLayout>
