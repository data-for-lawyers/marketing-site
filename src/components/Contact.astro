---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaLabel: string;
  ctaUrl: string;
  phone: string;
  email: string;
  formEyebrow?: string;
  formTitle?: string;
  submitLabel?: string;
  namePlaceholder?: string;
  phonePlaceholder?: string;
  emailPlaceholder?: string;
  messagePlaceholder?: string;
}

const {
  eyebrow,
  title,
  description,
  ctaLabel,
  ctaUrl,
  phone,
  email,
  formEyebrow = 'Message',
  formTitle = 'Send us a note',
  submitLabel = 'Send Message',
  namePlaceholder = 'Name',
  phonePlaceholder = 'Phone',
  emailPlaceholder = 'Email Address',
  messagePlaceholder = 'Message',
} = Astro.props;
const phoneHref = `tel:${phone.replace(/[^\d+]/g, '')}`;
---

<section id="contact" class="section contact-section">
  <div class="container-site">
    <div class="contact-layout reveal" data-reveal>
      <div class="contact-copy">
        <p class="section-kicker">{eyebrow}</p>
        <h2 class="contact-title">{title}</h2>
        <p class="contact-desc">{description}</p>

        <div class="contact-details">
          <a href={phoneHref} class="contact-detail">
            <span class="contact-detail-label">Phone</span>
            <span class="contact-detail-value">{phone}</span>
          </a>
          <a href={`mailto:${email}`} class="contact-detail">
            <span class="contact-detail-label">Email</span>
            <span class="contact-detail-value">{email}</span>
          </a>
        </div>

        {
          ctaLabel && ctaUrl && (
            <a href={ctaUrl} class="btn btn-dark contact-side-cta">
              {ctaLabel}
            </a>
          )
        }
      </div>

      <form class="contact-form" action="#" method="post">
        <p class="section-kicker">{formEyebrow}</p>
        <h3 class="contact-form-title">{formTitle}</h3>
        <div class="contact-form-fields">
          <label class="contact-field">
            <span class="contact-field-label">Name</span>
            <input class="form-input" type="text" name="name" placeholder={namePlaceholder} required />
          </label>
          <label class="contact-field">
            <span class="contact-field-label">Phone</span>
            <input class="form-input" type="tel" name="phone" placeholder={phonePlaceholder} />
          </label>
          <label class="contact-field">
            <span class="contact-field-label">Email</span>
            <input class="form-input" type="email" name="email" placeholder={emailPlaceholder} required />
          </label>
          <label class="contact-field">
            <span class="contact-field-label">Message</span>
            <textarea
              class="form-textarea"
              name="message"
              placeholder={messagePlaceholder}
              required
            ></textarea>
          </label>
        </div>
        <button type="submit" class="btn btn-primary contact-submit">{submitLabel}</button>
      </form>
    </div>
  </div>
</section>
