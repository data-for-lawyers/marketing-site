---
type Carrier = {
  name: string;
  logo?: string | null;
};

interface Props {
  carriers: readonly Carrier[];
  eyebrow?: string;
}

const { carriers, eyebrow = 'Coverage' } = Astro.props;
const rowOne = carriers.filter((_, index) => index % 2 === 0);
const rowTwo = carriers.filter((_, index) => index % 2 === 1);
const rows = [
  rowOne.length > 0 && { items: [...rowOne, ...rowOne], originalCount: rowOne.length, reverse: false },
  rowTwo.length > 0 && { items: [...rowTwo, ...rowTwo], originalCount: rowTwo.length, reverse: true },
].filter(Boolean) as { items: Carrier[]; originalCount: number; reverse: boolean }[];

function isMarkIcon(logo?: string | null) {
  if (!logo) return false;
  return /\/(att|verizon|tmobile|spectrum)\.svg(?:$|\?)/.test(logo);
}
---

{
  carriers.length > 0 && (
    <section class="section section-carriers">
      <div class="container-site">
        <p class="section-kicker carriers-kicker reveal" data-reveal>{eyebrow}</p>
      </div>
      <div class="logo-cloud reveal" data-reveal aria-label="Supported carriers">
        {rows.map((row) => (
          <div class:list={['logo-cloud-track', row.reverse && 'is-reverse']}>
            {row.items.map((carrier, index) => {
              const icon = isMarkIcon(carrier.logo);
              return (
                <div
                  class:list={['logo-pill', icon && 'is-icon']}
                  aria-label={index < row.originalCount ? carrier.name : undefined}
                  aria-hidden={index >= row.originalCount ? 'true' : undefined}
                >
                  {carrier.logo ? (
                    <img
                      src={carrier.logo}
                      alt=""
                      class:list={['logo-pill-img', icon && 'is-mark']}
                    />
                  ) : null}
                  {(icon || !carrier.logo) && <span class="logo-pill-name">{carrier.name}</span>}
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </section>
  )
}
