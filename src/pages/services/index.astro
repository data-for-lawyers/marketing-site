---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getServicesContent, getSharedCta } from '../../lib/content';
import { notFoundIfDisabled } from '../../lib/pages';

const { site, services } = await getServicesContent();
const disabled = notFoundIfDisabled(site.pagesEnabled, '/services');
if (disabled) return disabled;
const cta = getSharedCta(site);
const features = services.features;
---

<SiteLayout title={services.title} description={services.intro}>
  <PageHero eyebrow={services.eyebrow || services.title} title={services.subtitle} />

  <section class="section svc-intro-section">
    <div class="container-site">
      <div class="svc-intro-layout reveal" data-reveal>
        <div class="svc-intro">
          <p class="section-kicker">{services.introEyebrow || 'Overview'}</p>
          <h2 class="svc-intro-title">{services.introTitle}</h2>
          <p class="svc-intro-copy">{services.intro}</p>
        </div>
        {
          services.introImage && (
            <div class="svc-intro-media">
              <img src={services.introImage} alt="" />
            </div>
          )
        }
      </div>
    </div>
  </section>

  {
    features.length > 0 && (
      <section class="section svc-steps-section">
        <div class="container-site">
          <div class="svc-steps-intro reveal" data-reveal>
            <p class="section-kicker">{services.platformEyebrow || 'Platform'}</p>
            <h2 class="svc-steps-title">{services.platformTitle}</h2>
            <p class="svc-steps-lead">{services.platformDescription}</p>
          </div>

          <ol class="svc-steps">
            {features.map((feature, index) => (
              <li
                class="svc-step reveal"
                data-reveal
                style={`--reveal-delay: ${index * 70}ms; --step-accent: ${
                  index % 2 === 0 ? 'var(--color-cyan)' : 'var(--color-orange)'
                }`}
              >
                <span class="svc-step-num" aria-hidden="true">
                  {String(index + 1).padStart(2, '0')}
                </span>
                {feature.image && (
                  <div class="svc-step-media">
                    <img src={feature.image} alt="" />
                  </div>
                )}
                <div class="svc-step-copy">
                  <h3 class="svc-step-title">{feature.title}</h3>
                  <p class="svc-step-desc">{feature.description}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )
  }

  <section id="offerings" class="section svc-pathways-section">
    <div class="container-site">
      <div class="svc-pathways-intro is-center reveal" data-reveal>
        <p class="section-kicker is-light">{services.pathwaysEyebrow || 'Pathways'}</p>
        <h2 class="svc-pathways-title">{services.pathwaysTitle}</h2>
        <p class="svc-pathways-lead">{services.pathwaysDescription}</p>
      </div>

      <div class="svc-pathway-list">
        {
          services.offerings.map((offering, index) => (
            <article
              id={`offering-${index}`}
              class:list={['svc-detail', index % 2 === 1 && 'is-reversed', 'reveal']}
              data-reveal
              style={`--reveal-delay: ${index * 90}ms`}
            >
              <div class="svc-detail-copy">
                <p class="section-kicker is-light svc-detail-kicker">
                  Pathway {String(index + 1).padStart(2, '0')}
                </p>
                <h3 class="svc-detail-title">{offering.title}</h3>
                <p class="svc-detail-desc">{offering.description}</p>
                <p class="svc-detail-label">{services.offeringsLabel}</p>
                <ul class="svc-detail-bullets">
                  {offering.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>

              <div class="svc-detail-media">
                {offering.image ? (
                  <img src={offering.image} alt="" />
                ) : (
                  <div class="svc-detail-media-fallback" aria-hidden="true" />
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title={services.ctaTitle || cta.title}
    description={services.ctaDescription || ''}
    eyebrow={services.ctaEyebrow || 'Get Started'}
    primaryLabel={cta.primaryLabel}
    points={cta.points}
  />
</SiteLayout>
