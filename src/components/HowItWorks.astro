---
import { withBase } from '../lib/paths';

type Item = {
  title: string;
  description: string;
};

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  items: readonly Item[];
  signInUrl?: string;
  ctaLabel?: string;
}

const { eyebrow, title, description, items, ctaLabel = 'Get started' } = Astro.props;
const ctaUrl = withBase('/contact-us');
---

<section id="how-it-works" class="section process-section">
  <div class="container-site section-stack">
    <div class="process-intro reveal" data-reveal>
      {eyebrow && <p class="process-kicker">{eyebrow}</p>}
      <h2 class="process-heading">{title}</h2>
      <p class="process-lead">{description}</p>
    </div>

    <div class="process-flow reveal" data-reveal style="--reveal-delay: 80ms">
      {
        items.map((step, index) => (
          <>
            <article class="process-flow-step">
              <p class="process-flow-num" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </p>
              <div class="process-flow-icon" aria-hidden="true">
                {index % 4 === 0 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3v12" />
                    <path d="M8 7l4-4 4 4" />
                    <path d="M5 14v4a2 2 0 002 2h10a2 2 0 002-2v-4" />
                  </svg>
                )}
                {index % 4 === 1 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" />
                  </svg>
                )}
                {index % 4 === 2 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" />
                    <path d="M9.5 12l1.8 1.8 3.7-3.7" />
                  </svg>
                )}
                {index % 4 === 3 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 7h16v12H4z" />
                    <path d="M4 7l8 5 8-5" />
                    <path d="M9 3h6v4H9z" />
                  </svg>
                )}
              </div>
              <h3 class="process-flow-title">{step.title}</h3>
              <p class="process-flow-desc">{step.description}</p>
            </article>

            {index < items.length - 1 && (
              <div class="process-flow-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </div>
            )}
          </>
        ))
      }
    </div>

    <div class="process-cta reveal" data-reveal>
      <a href={ctaUrl} class="btn btn-primary">{ctaLabel}</a>
    </div>
  </div>
</section>
