---
---

<div class="product-shell">
  <div class="product-topbar">
    <span class="product-dot"></span>
    <span class="product-dot"></span>
    <span class="product-dot"></span>
    <span class="ml-2 text-[0.8125rem] font-medium text-[var(--color-muted)]">Request dashboard</span>
  </div>

  <div class="grid gap-3 p-4 md:p-5">
    <div class="grid gap-3 sm:grid-cols-3">
      <div class="stat-card">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-muted)]">Active requests</p>
        <p class="stat-value mt-2">128</p>
        <p class="stat-label">Across 14 carriers</p>
      </div>
      <div class="stat-card">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-muted)]">Avg. turnaround</p>
        <p class="stat-value mt-2">12d</p>
        <p class="stat-label">Authenticated delivery</p>
      </div>
      <div class="stat-card">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-muted)]">Chain of custody</p>
        <p class="stat-value mt-2">100%</p>
        <p class="stat-label">Verified documentation</p>
      </div>
    </div>

    <div class="overflow-hidden rounded-[0.75rem] border border-[var(--color-border)]">
      <div class="flex items-center justify-between border-b border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3">
        <div>
          <p class="text-sm font-semibold text-[var(--color-ink)]">Carrier records queue</p>
          <p class="text-xs text-[var(--color-muted)]">Live status across open matters</p>
        </div>
        <span class="status-pill bg-emerald-50 text-emerald-700">Live</span>
      </div>
      <div class="divide-y divide-[var(--color-border)] bg-white">
        <div class="flex items-center justify-between gap-4 px-4 py-3">
          <div>
            <p class="text-sm font-medium text-[var(--color-ink)]">State v. Martinez</p>
            <p class="text-xs text-[var(--color-muted)]">Verizon · DWQ · Authenticated PDF ready</p>
          </div>
          <span class="status-pill bg-[var(--color-cyan-soft)] text-teal">Delivered</span>
        </div>
        <div class="flex items-center justify-between gap-4 px-4 py-3">
          <div>
            <p class="text-sm font-medium text-[var(--color-ink)]">Thompson Injury Claim</p>
            <p class="text-xs text-[var(--color-muted)]">AT&T · Subpoena · Carrier response pending</p>
          </div>
          <span class="status-pill bg-[var(--color-orange-soft)] text-[var(--color-orange-dark)]">In review</span>
        </div>
        <div class="flex items-center justify-between gap-4 px-4 py-3">
          <div>
            <p class="text-sm font-medium text-[var(--color-ink)]">Rivera Custody Matter</p>
            <p class="text-xs text-[var(--color-muted)]">T-Mobile · Preservation · Submitted today</p>
          </div>
          <span class="status-pill bg-[var(--color-surface)] text-[var(--color-muted)]">Submitted</span>
        </div>
      </div>
    </div>
  </div>
</div>
