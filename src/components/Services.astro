---
import { withBase } from '../lib/paths';

type Service = {
  title: string;
  description: string;
  bullets?: readonly string[];
  image?: string | null;
};

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  services: readonly Service[];
}

const { title, description, eyebrow = 'Capabilities', services } = Astro.props;
const items = services.filter((service) => service.image).slice(0, 5);
---

{
  items.length > 0 && (
    <section id="platform" class="section capability-section">
      <div class="capability-intro reveal" data-reveal>
        <div class="container-site">
          <p class="section-kicker capability-kicker">{eyebrow}</p>
          <h2 class="capability-title">{title}</h2>
          {description && <p class="capability-copy">{description}</p>}
        </div>
      </div>

      <div class="capability-rail reveal" data-reveal style="--reveal-delay: 90ms">
        <div class="capability-track">
          {items.map((service, index) => (
            <a
              href={withBase('/services')}
              class="capability-card"
              style={`--card-accent: ${index % 2 === 0 ? 'var(--color-cyan)' : 'var(--color-orange)'}`}
            >
              <div class="capability-card-media">
                <img src={service.image!} alt="" />
              </div>
              <div class="capability-card-body">
                <span class="capability-card-index" aria-hidden="true">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <h3 class="capability-card-title">{service.title}</h3>
                <p class="capability-card-desc">{service.description}</p>
                {service.bullets && service.bullets.length > 0 && (
                  <ul class="capability-card-tags">
                    {service.bullets.slice(0, 3).map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="container-site capability-footer reveal" data-reveal style="--reveal-delay: 140ms">
        <p class="capability-hint">Drag or scroll to explore</p>
        <a class="capability-cta" href={withBase('/services')}>
          Explore all services
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17L17 7M9 7h8v8" />
          </svg>
        </a>
      </div>
    </section>
  )
}
