---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getBlogPageContent, getSite } from '../../lib/content';
import { notFoundIfDisabled } from '../../lib/pages';
import { withBase } from '../../lib/paths';
import { formatPostDate, getPostPageData, getPublishedPostSummaries } from '../../lib/posts';

export async function getStaticPaths() {
  const site = await getSite();
  if (!site.pagesEnabled.blog) return [];

  const posts = await getPublishedPostSummaries();

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const slug = Astro.params.slug;

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const [{ site, blog }, post] = await Promise.all([getBlogPageContent(), getPostPageData(slug)]);
const disabled = notFoundIfDisabled(site.pagesEnabled, '/blog');
if (disabled) return disabled;

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}
---

<SiteLayout title={post.title} description={post.excerpt}>
  <PageHero eyebrow={blog.eyebrow || blog.title} title={post.title} />

  {
    post.coverImage && (
      <section class="blog-post-cover-section">
        <div class="blog-post-cover reveal" data-reveal>
          <img src={post.coverImage} alt="" />
        </div>
      </section>
    )
  }

  <article class="section section-light blog-post-body">
    <div class="container-site">
      <a href={withBase('/blog')} class="text-link">{blog.backLabel}</a>

      <header class="mt-8 max-w-3xl">
        <p class="eyebrow">
          {formatPostDate(post.publishedDate)} · {post.author}
        </p>
        <p class="section-copy mt-4">{post.excerpt}</p>
      </header>

      <div class="prose mt-10 max-w-3xl" set:html={post.html} />
    </div>
  </article>
</SiteLayout>
