---
import SectionHeader from './SectionHeader.astro';

type Item = {
  title: string;
  description: string;
};

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  items: readonly Item[];
  signInUrl: string;
  ctaLabel?: string;
}

const { eyebrow, title, description, items, signInUrl, ctaLabel = 'Get started' } = Astro.props;
---

<section id="how-it-works" class="section process-section">
  <div class="container-site section-stack">
    <div class="reveal" data-reveal>
      <SectionHeader
        eyebrow={eyebrow}
        title={title}
        description={description}
        align="center"
        tone="dark"
      />
    </div>

    <ol class="process-journey">
      {
        items.map((step, index) => (
          <li
            class="process-node reveal"
            data-reveal
            style={`--reveal-delay: ${index * 100}ms`}
          >
            <div class="process-node-marker" aria-hidden="true">
              <span class="process-node-ring">
                {index % 4 === 0 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3v12" />
                    <path d="M8 7l4-4 4 4" />
                    <path d="M5 14v4a2 2 0 002 2h10a2 2 0 002-2v-4" />
                  </svg>
                )}
                {index % 4 === 1 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" />
                  </svg>
                )}
                {index % 4 === 2 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" />
                    <path d="M9.5 12l1.8 1.8 3.7-3.7" />
                  </svg>
                )}
                {index % 4 === 3 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 7h16v12H4z" />
                    <path d="M4 7l8 5 8-5" />
                    <path d="M9 3h6v4H9z" />
                  </svg>
                )}
              </span>
              <span class="process-node-num">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <div class="process-node-body">
              <h3 class="process-title">{step.title}</h3>
              <p class="process-desc">{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="process-cta reveal" data-reveal>
      <a href={signInUrl} class="btn btn-primary">{ctaLabel}</a>
    </div>
  </div>
</section>
