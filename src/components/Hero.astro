---
interface Props {
  title: string;
  subtitle: string;
  ctaLabel: string;
  ctaUrl: string;
  imageUrl: string;
}

const { title, subtitle, ctaLabel, ctaUrl, imageUrl } = Astro.props;
---

<section class="hero-shell">
  <div class="hero-media" aria-hidden="true">
    <img class="hero-media-img" src={imageUrl} alt="" />
    <div class="hero-media-wash"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-animate hero-copy">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>

      <div class="hero-actions">
        <a href={ctaUrl} class="btn btn-primary">{ctaLabel}</a>
        <a href="#platform" class="hero-secondary">
          See the platform
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17L17 7M9 7h8v8" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="hero-edge" aria-hidden="true"></div>
</section>
