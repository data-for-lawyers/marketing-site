---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getTermsContent } from '../../lib/content';

const { site, terms } = await getTermsContent();
---

<SiteLayout title={terms.title} description={terms.description}>
  <PageHero title={terms.title} eyebrow={terms.eyebrow} />

  <section class="section section-light">
    <div class="container-site">
      <PageIntro title={terms.introTitle} description={terms.intro} />

      <div class="prose mx-auto max-w-3xl rounded-[1.5rem] border border-[var(--color-border)] bg-white p-8 md:p-12">
        {
          terms.sections.map((section) => (
            <>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
            </>
          ))
        }
        <p>
          Contact <a href={`mailto:${site.email}`}>{site.email}</a> or call{' '}
          <a href={`tel:${site.phone.replace(/[^\d+]/g, '')}`}>{site.phone}</a>.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
