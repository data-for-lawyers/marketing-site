---
import SectionHeader from './SectionHeader.astro';

type Member = {
  name: string;
  description: string;
  image: string;
};

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  members: readonly Member[];
}

const { eyebrow, title, description, members } = Astro.props;
---

<section id="team" class="section section-light">
  <div class="container-site section-stack">
    <SectionHeader eyebrow={eyebrow} title={title} description={description} />

    <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-4">
      {
        members.map((member) => (
          <article>
            <img src={member.image} alt={member.name} class="media-cover media-3-4 w-full" />
            <h3 class="mt-5">{member.name}</h3>
            <p class="body-copy mt-2">{member.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
